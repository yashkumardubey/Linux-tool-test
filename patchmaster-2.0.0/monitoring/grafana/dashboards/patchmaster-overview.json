{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Hosts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "patchmaster_hosts_total", "legendFormat": "Hosts" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "blue", "value": null}] } } }
    },
    {
      "title": "Online Hosts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "patchmaster_hosts_online", "legendFormat": "Online" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": null}] } } }
    },
    {
      "title": "Reboot Required",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "patchmaster_hosts_reboot_required", "legendFormat": "Reboot" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}] } } }
    },
    {
      "title": "Avg Compliance Score",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "patchmaster_compliance_avg_score", "legendFormat": "Compliance" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 50}, {"color": "yellow", "value": 80}, {"color": "green", "value": 95}] } } }
    },
    {
      "title": "Upgradable Packages",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "patchmaster_packages_upgradable_total", "legendFormat": "Upgradable" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}] } } }
    },
    {
      "title": "CVEs Critical (Unpatched)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 20, "y": 0 },
      "targets": [{ "expr": "patchmaster_cve_unpatched_total{severity=\"critical\"}", "legendFormat": "Critical" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}] } } }
    },
    {
      "title": "CVEs by Severity",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [{ "expr": "patchmaster_cve_total", "legendFormat": "{{severity}}" }],
      "fieldConfig": { "defaults": {} }
    },
    {
      "title": "Unpatched CVEs by Severity",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [{ "expr": "patchmaster_cve_unpatched_total", "legendFormat": "{{severity}}" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 3}, {"color": "red", "value": 10}] } } }
    },
    {
      "title": "Patch Jobs by Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "targets": [{ "expr": "patchmaster_jobs_total", "legendFormat": "{{status}}" }],
      "fieldConfig": { "defaults": {} }
    },
    {
      "title": "API Request Rate (5m avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "rate(patchmaster_api_requests_total[5m])", "legendFormat": "{{method}} {{path}} {{status}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "API Latency p95 (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(patchmaster_api_request_duration_seconds_bucket[5m]))", "legendFormat": "p95 {{method}} {{path}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Agent Patch Job Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{ "expr": "patch_job_status", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "mappings": [{"type": "value", "options": {"0": {"text": "Idle"}, "1": {"text": "Running"}, "2": {"text": "Success"}, "3": {"text": "Failed"}}}] } }
    },
    {
      "title": "Hosts Online Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "patchmaster_hosts_total", "legendFormat": "Total" },
        { "expr": "patchmaster_hosts_online", "legendFormat": "Online" }
      ],
      "fieldConfig": { "defaults": {} }
    }
  ],
  "schemaVersion": 39,
  "tags": ["patchmaster", "linux", "patching"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "PatchMaster Overview",
  "uid": "patchmaster-overview",
  "version": 1
}
