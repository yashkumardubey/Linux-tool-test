##############################################################################
#  PatchMaster — Vendor Portal Environment Configuration
#  Copy to .env and fill in required values before deploying.
##############################################################################

# ── App Settings ──
CM_SECRET_KEY=                      # [REQUIRED] Random 64-char hex (python -c "import secrets; print(secrets.token_hex(32))")
CM_ADMIN_USER=admin
CM_ADMIN_PASS=                      # [REQUIRED] Strong admin password

# ── Database ──
CM_DB_PATH=/app/data/customers.db   # SQLite database path (inside container)

# ── License Signing ──
LICENSE_SIGN_KEY=PatchMaster-License-SignKey-2026-Secure

# ── Server ──
CM_HOST=0.0.0.0
CM_PORT=5050
CM_WORKERS=2                        # Gunicorn worker count

# ── Nginx (reverse proxy) ──
VENDOR_PORT=8080                    # External HTTP port
# VENDOR_SSL_PORT=8443              # External HTTPS port
# SSL_CERT_DIR=./certs              # Directory containing fullchain.pem & privkey.pem
# HTTPS_ENABLED=true                # Enable secure cookies when behind TLS
