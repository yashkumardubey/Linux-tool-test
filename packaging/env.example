##############################################################################
#  PatchMaster -- Environment Configuration
#  Copy this file to .env and edit before running install.sh
##############################################################################

# ── Networking ──
# IP or hostname that agents and browsers use to reach this server.
# Auto-detected during install if left blank.
SERVER_IP=

# Service ports (change if defaults conflict)
FRONTEND_PORT=3000
BACKEND_PORT=8000
# GRAFANA_PORT=3001        # Also available in monitoring section below
# PROMETHEUS_PORT=9090      # Also available in monitoring section below

# ── Database ──
POSTGRES_USER=patchmaster
POSTGRES_PASSWORD=patchmaster
POSTGRES_DB=patchmaster

# ── Security ──
# CHANGE THIS to a random 32+ character string in production!
JWT_SECRET=change-me-to-a-secure-random-string

# JWT token expiry in minutes (default 8 hours)
TOKEN_EXPIRE_MINUTES=480

# ── License ──
# Signing key must match what was used to generate license keys
# (same --secret value passed to tools/generate-license.py)
LICENSE_SIGN_KEY=PatchMaster-License-SignKey-2026-Secure

# ── Monitoring (optional — only used with: install-bare.sh --with-monitoring) ──
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=patchmaster
PROMETHEUS_RETENTION=30d

# ── Docker ──
# Project name prefix for containers
COMPOSE_PROJECT_NAME=patchmaster
